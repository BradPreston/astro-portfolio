---
type Props = {
    subtitle: string;
    layout: "centered" | "row";
}
const { subtitle, layout } = Astro.props;
---
<section class={`headingBlock ${layout === "centered" && "centered-title"}`}>
    <p class="subtitle">{subtitle}</p>
    <div class="styled-title">
        <slot name="title" />
        <slot name="button" />
    </div>
</section>

<style>
    .headingBlock {
        margin-bottom: 3rem;
    }

    .subtitle {
        font-family: var(--roboto);
        color: var(--dark);
        position: relative;
        width: fit-content;
        padding-left: 1.5rem;
        font-size: 1.2rem;
        margin: 0 auto;
        margin-bottom: 0.75rem;

        &::before {
            position: absolute;
            content: "";
            width: 1rem;
            height: 2px;
            background: var(--secondary);
            top: 50%;
            left: 0;
            transform: translateY(-50%);
        }
    }

    .styled-title {
        color: var(--dark);
        font-size: 2rem;
        font-family: var(--roboto);
        font-weight: 500;
        display: flex;
        justify-content: center;
        align-items: flex-end;
        text-align: center;

        em {
            color: var(--secondary);
            font-weight: normal;
        }
        
        .button.button-primary {
            display: none;
        }
    }

    .centered-title {
        text-align: center;
        marign: 0 auto;

        em {
            display: block;
        }

        .subtitle {
            margin: 0 auto;
        }

        .styled-title {
            justify-content: center;
            align-items: center;
        }
    }

    @media screen and (min-width: 801px) {
        .subtitle {
            margin: unset;
            margin-bottom: 0.75rem;
        }
        .styled-title {
            justify-content: space-between;

            .button.button-primary {
                display: block;
            }
        }
    }
</style>
