---
import { Icon } from 'astro-icon/components';

type Props = {
    link: string;
    thumbnail: {
        src: string;
        alt: string;
    };
    tags: string[];
    title: string;
}
const { link, thumbnail, tags, title }: Props = Astro.props;
---
<article class="projectCard">
    <a href={link}>
        <img src={thumbnail.src} alt={thumbnail.alt} />
    </a>
    <ul>{tags.map(tag => <li>{tag}</li>)}</ul>
    <a href={link} class="title">
        {title}
        <span class="icon">
            <Icon name="lucide:arrow-right" size="28" />
        </span>
    </a>
</article>

<style>
    .projectCard {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        padding: 1rem;
        border-radius: 1rem;
        background: var(--white);
        container-type: inline-size;
        container-name: projectCard;

        img {
            width: 100%;
            aspect-ratio: 1/1;
            object-fit: cover;
            border-radius: 0.5rem;
        }

        ul {
            display: flex;
            margin: 0;
            list-style: none;
            gap: 0.5rem;

            li {
                background: var(--secondary);
                color: var(--dark);
                border-radius: 9999px;
                font-family: var(--roboto);
                padding: 0.5rem 1rem;
                font-size: 1.15rem;
            }
        }

        .title {
            margin-top: 0.5rem;
            text-decoration: none;
            font-family: var(--roboto);
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 1rem;
            color: var(--dark);
            font-weight: 600;
            font-size: 1.5rem;

            .icon {
                background: var(--primary);
                color: var(--secondary);
                border-radius: 9999px;
                padding: 0.5rem;
                display: inline-flex;
            }
        }
    }

    @container projectCard (width < 360px) {
        ul li {
            font-size: 0.8rem;
        }
    }
</style>