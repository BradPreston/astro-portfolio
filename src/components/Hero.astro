---
    const startWorkYear = new Date('7/1/2021');
    const today = new Date();
    const yearsOfExperience = today.getFullYear() - startWorkYear.getFullYear();
---

<section class="hero">
    <div class="hero-left">
        <div class="styled-subheading">
            <span class="corner-block"></span>
            <span class="corner-block"></span>
            <span class="corner-block"></span>
            <span class="corner-block"></span>
            Hello there!
        </div>
        <h1>I'm <span class="styled-text">Brad Preston,</span><br>Web Developer<br>Based in Michigan.</h1>
        <p>I'm an experienced Web Developer with {yearsOfExperience}+ years of experience in the field, collaborating with several companies in various industries.</p>
        <div class="button-group">
            <a href="/" class="button button-primary">View My Portfolio</a>
            <a href="/" class="button button-outline">Download Resume</a>
        </div>
    </div>
    <div class="hero-right">
        <div class="blob"></div>
    </div>
</section>

<style>
    .hero {
        --blob-min-size: 300px;

        display: flex;
        width: 100%;
        justify-content: space-between;
        align-items: stretch;
        gap: 4rem;
        padding: 5rem 2rem;
        padding-top: 0;
        container-type: inline-size;
        container-name: hero;
    }

    .hero-left {
        flex: 1 1 484px;
        min-width: 0;
        min-height: var(--blob-min-size);
        width: auto;
        max-width: 484px;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .styled-subheading {
        position: relative;
        width: fit-content;
        font-family: var(--roboto);
        font-size: 1.5rem;
        padding: 0.5rem 1rem;
        border: 2px solid var(--dark);
        color: var(--dark);
    }

    .corner-block {
        position: absolute;
        background: var(--secondary);
        border: 2px solid var(--dark);
        width: 15px;
        height: 11px;
        display: block;

        &:nth-of-type(1) {
            top: calc(-0.25rem - 2px);
            left: calc(-0.5rem - 1px);
        }

        &:nth-of-type(2) {
            top: calc(-0.25rem - 2px);
            right: calc(-0.5rem - 1px);
        }

        &:nth-of-type(3) {
            bottom: calc(-0.25rem - 2px);
            left: calc(-0.5rem - 1px);
        }

        &:nth-of-type(4) {
            bottom: calc(-0.25rem - 2px);
            right: calc(-0.5rem - 1px);
        }
    }

    h1 {
        font-family: var(--roboto);
        font-weight: 500;
        font-size: clamp(2.25rem, 11cqw, 3.4rem);
    }

    .styled-text {
        color: var(--secondary);
        position: relative;
        font-style: italic;
        display: inline-block;
        width: fit-content;

        &:after {
            content: "";
            position: absolute;
            height: 2px;
            width: 100%;
            bottom: -2px;
            left: 0;
            background: var(--secondary);
        }
    }

    p {
        font-size: 1rem;
        font-family: var(--roboto);
    }

    .button-group {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 1rem;
    }

    .button {
        font-size: 1rem;
        font-family: var(--roboto);
        padding: 1rem 2rem;
        border-radius: 9999px;
        text-decoration: none;
        transition: all 200ms ease;
    }

    .button-primary {
        background: var(--primary);
        color: var(--light);
        border: 2px solid var(--primary);

        &:hover {
            background: var(--secondary);
            color: var(--primary);
        }
    }

    .button-outline {
        border: 2px solid var(--dark);
        color: var(--dark);

        &:hover {
            background: var(--dark);
            color: var(--light);
        }
    }

    .hero-right {
        flex: 1 0 var(--blob-min-size);
        min-width: var(--blob-min-size);
        position: relative;
        overflow: hidden;
        container-type: size;
    }

    .blob {
        background: var(--secondary);
        position: absolute;
        top: 50%;
        right: 0;
        width: clamp(var(--blob-min-size), min(100cqw, 100cqh), 520px);
        aspect-ratio: 1;
        transform: translateY(-50%);
        clip-path: shape(from 87.69% 10.08%,curve to 87.69% 76.75% with 112.31% 30.25%,curve to 21.02% 76.75% with 63.06% 123.25%,curve to 21.02% 10.08% with -21.02% 30.25%,curve to 87.69% 10.08% with 63.06% -10.08%);
    }

    @media screen and (min-width: 801px) {  
        .hero {
            padding: 5rem 0;
        }
    }

    @container hero (width < 950px) {
        h1 {
            font-size: 2rem;
        }
    }

    @container hero (width < 650px) {
        .hero-left {
            max-width: 100%;
            align-items: center;
        }

        .hero-right {
            display: none;
        }

        h1 {
            text-align: center;
        }

        p {
            text-align: center;
        }
    }

    @container hero (width < 411px) {
        .button {
            width: 100%;
            text-align: center;
        }
    }
</style>
